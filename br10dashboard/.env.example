# =============================================================================
# BR10 Dashboard - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# =============================================================================
# DIRETÓRIOS
# =============================================================================
BASE_DIR=/opt/br10dashboard
BLOCKED_DOMAINS_PATH=/var/lib/br10api/blocked_domains.txt
HISTORY_DIR=/opt/br10dashboard/data/history
LOG_DIR=/opt/br10dashboard/logs
UNBOUND_ZONE_FILE=/var/lib/unbound/br10block-rpz.zone
USERS_FILE=/opt/br10dashboard/config/users.json

# =============================================================================
# SERVIDOR BR10 BLOCK WEB (CENTRAL)
# =============================================================================
# URL do servidor central BR10 Block Web
BR10_SERVER_URL=http://IP_DO_SERVIDOR:8084

# API Key gerada no painel admin do servidor
# Acesse: http://IP_DO_SERVIDOR:8084/clients -> Criar cliente -> copiar API Key
BR10_API_KEY=SUA_API_KEY_AQUI

# Caminho do script de sincronização (opcional, usa Python direto se não existir)
BR10_SYNC_SCRIPT=/opt/br10dashboard/scripts/br10block_client.sh

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=300

# =============================================================================
# FLASK
# =============================================================================
SECRET_KEY=mude_esta_chave_em_producao_use_openssl_rand_hex_32
SESSION_LIFETIME_HOURS=24

# =============================================================================
# UNBOUND
# =============================================================================
# Arquivo de zona RPZ do Unbound (gerado pelo script de sincronização)
UNBOUND_ZONE_FILE=/var/lib/unbound/br10block-rpz.zone

# =============================================================================
# CRON DE SINCRONIZAÇÃO AUTOMÁTICA
# =============================================================================
# Configure o crontab para sincronizar automaticamente:
# crontab -e
# */5 * * * * BR10_SERVER_URL=http://IP:8084 BR10_API_KEY=SUA_KEY /opt/br10dashboard/scripts/br10block_client.sh >> /var/log/br10block_client.log 2>&1
